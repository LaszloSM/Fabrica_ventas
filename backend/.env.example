# App
APP_NAME="CoimpactoB CRM API"
DEBUG=False

# Cosmos DB (MongoDB compatible)
COSMOS_CONNECTION_STRING=mongodb+srv://<user>:<password>@<cosmos>.mongo.cosmos.azure.com/?ssl=true&replicaSet=globaldb&retryWrites=false
COSMOS_DATABASE=fabrica_ventas

# Groq AI (GRATIS - $0/mes)
# Obtén tu API key GRATIS en: https://console.groq.com
GROQ_API_KEY=gsk_YOUR_FREE_API_KEY_HERE
GROQ_MODEL=mixtral-8x7b-32768

# Email (SendGrid - opcional)
# Para usar alertas por email, obtén key en: https://sendgrid.com
SENDGRID_API_KEY=SG_YOUR_KEY_HERE
SENDGRID_FROM_EMAIL=noreply@coimpactob.com

# JWT Security
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
