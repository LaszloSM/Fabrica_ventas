FROM node:20-alpine AS builder

WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM node:20-alpine AS runner

WORKDIR /app
COPY package*.json ./
RUN npm ci --omit=dev
COPY --from=builder /app/dist ./dist
COPY server.ts ./
COPY tsconfig*.json ./

RUN npm install -g tsx

EXPOSE 8080

ENV NODE_ENV=production

CMD ["tsx", "server.ts"]
